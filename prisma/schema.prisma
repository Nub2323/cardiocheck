generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Patient {
  id        String    @id @default(cuid())
  name      String
  dni       String    @unique
  birthDate DateTime? // Fecha de nacimiento - verificación de identidad
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  checkIns  CheckIn[]
}

model CheckIn {
  id        String          @id @default(cuid())
  patientId String
  patient   Patient         @relation(fields: [patientId], references: [id])
  comment   String?
  severity  String          @default("green") // overall severity: green, neutral, yellow, red
  createdAt DateTime        @default(now())
  answers   CheckInAnswer[]
  alert     Alert?
}

model CheckInAnswer {
  id           String   @id @default(cuid())
  checkInId    String
  checkIn      CheckIn  @relation(fields: [checkInId], references: [id], onDelete: Cascade)
  questionIndex Int
  question     String
  answer       String
  severity     String // green, neutral, yellow-low, yellow, yellow-high, red
}

model Alert {
  id        String   @id @default(cuid())
  checkInId String   @unique
  checkIn   CheckIn  @relation(fields: [checkInId], references: [id], onDelete: Cascade)
  status    String   @default("pending") // pending, acknowledged, dismissed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminPin {
  id    String @id @default(cuid())
  pin   String @unique
  label String?
}

model Question {
  id         String   @id @default(cuid())
  order      Int      @default(0)
  emoji      String   @default("❓")
  question   String
  options    String   // JSON array: [{label, severity}]
  isActive   Boolean  @default(true)
  isCritical Boolean  @default(false) // If true, any non-green answer → guardia alert
  category   String   @default("general") // general, respiratory, cardiac, etc.
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AppSetting {
  key       String   @id // e.g. "whatsapp_number", "doctor_phone", "doctor_email", "app_name"
  value     String
  label     String   // Human-readable label for the admin UI
  updatedAt DateTime @updatedAt
}
